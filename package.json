{
  "name": "opengarlic.server",
  "version": "1.0.0",
  "description": "Express Server Hosting OpenGarlic",
  "type": "module",
  "engines": {
    "node": ">=18.x"
  },
  "main": "server.js",
  "scripts": {
    "start": "node -r dotenv/config server.js",
    "build": "env-cmd --use-shell \"cd client/ && npm install && npm run build\"",
    "dev-server": "cross-env NODE_ENV=development node -r dotenv/config server.js",
    "dev-client": "env-cmd --use-shell \"cd client && npm start\"",
    "dev": "concurrently --kill-others-on-fail \"npm run dev-server\" \"npm run dev-client\""
  },
  "dependencies": {
    "@socket.io/admin-ui": "^0.5.1",
    "body-parser": "^2.2.2",
    "canvas": "^3.2.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "filenamify": "^7.0.1",
    "helmet": "^8.2.0",
    "konva": "^10.3.0",
    "nanoid": "^5.1.15",
    "pino": "^10.3.1",
    "rate-limiter-flexible": "^11.2.0",
    "redis": "^6.0.0",
    "serve-favicon": "^2.5.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "env-cmd": "^11.0.0"
  },
  "overrides": {
    "nth-check": "2.1.1"
  }
}
